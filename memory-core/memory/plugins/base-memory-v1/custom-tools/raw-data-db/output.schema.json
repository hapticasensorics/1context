{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "raw_data.query output",
  "type": "object",
  "required": ["database", "columns", "rows", "row_count", "truncated"],
  "additionalProperties": false,
  "properties": {
    "database": {
      "type": "string"
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "row_count": {
      "type": "integer",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean"
    }
  }
}
